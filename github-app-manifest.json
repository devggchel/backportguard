{
  "name": "BackportGuard",
  "url": "https://backportguard.space/",
  "description": "Free, open-source GitHub backport reminder service.",
  "public": false,
  "hook_attributes": {
    "url": "https://api.backportguard.space/webhooks/github",
    "active": true
  },
  "default_permissions": {
    "contents": "read",
    "pull_requests": "read",
    "issues": "write"
  },
  "default_events": [
    "pull_request"
  ]
}
