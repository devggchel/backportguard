# Generate a long random value; do not commit the populated file.
WEBHOOK_SECRET=
# Prefer GitHub App credentials in production. GITHUB_TOKEN is for local development only.
GITHUB_APP_ID=
GITHUB_INSTALLATION_ID=
GITHUB_PRIVATE_KEY_PATH=/etc/backportguard/github-app.pem
DATABASE_PATH=/var/lib/backportguard/backportguard.sqlite3
